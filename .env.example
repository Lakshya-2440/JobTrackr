PORT=5000
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/jobtracker?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/jobtracker?sslmode=require&pgbouncer=true
JWT_SECRET=replace-with-a-32-character-or-longer-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-a-different-32-character-or-longer-secret
JWT_REFRESH_EXPIRES_IN=30d
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5
# Production: your Vercel URL. Multiple origins: comma-separated (e.g. prod + preview).
CLIENT_URL=http://localhost:5173
NODE_ENV=development
VITE_API_URL=/api

